# Session signing (use a long random string in production)
SESSION_SECRET=

# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Publishable key (pk_...) — for Stripe.js in the browser; also available at GET /api/stripe-config
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create Products + recurring or one-time Prices in Stripe Dashboard, then paste Price IDs (price_...)
STRIPE_PRICE_MATCHING=price_
# Optional; checkout for "Abundant" uses this if unset (same as matching price).
STRIPE_PRICE_ABUNDANT=
STRIPE_PRICE_LOVE_LETTER=price_
STRIPE_PRICE_DATE_NIGHT=price_
STRIPE_PRICE_MEMORY=price_

# Optional: defaults to http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
