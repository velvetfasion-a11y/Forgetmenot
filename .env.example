# Copy this file to ".env" in the same folder as server.js and fill in real values.
# Full step-by-step for Stripe Elements checkout: docs/stripe-elements-env.md

# Session signing (use a long random string in production)
SESSION_SECRET=

# Dashboard → Developers → API keys (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY: sk_test_... or sk_live_... — server ONLY; never expose in the browser
STRIPE_SECRET_KEY=sk_test_...

# STRIPE_PUBLISHABLE_KEY: pk_test_... or pk_live_... — safe for Stripe.js; also served at GET /api/stripe-config
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create Products + recurring or one-time Prices in Stripe Dashboard, then paste Price IDs (price_...)
STRIPE_PRICE_MATCHING=price_
# Optional; checkout for "Abundant" uses this if unset (same as matching price).
STRIPE_PRICE_ABUNDANT=
STRIPE_PRICE_LOVE_LETTER=price_
STRIPE_PRICE_DATE_NIGHT=price_
STRIPE_PRICE_MEMORY=price_

# Optional: defaults to http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
